{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LiveCaption",
  "version": "0.5.0",
  "identifier": "com.dimfi.livecaption",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "LiveCaption",
        "width": 980,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "LiveCaption Overlay",
        "url": "index.html",
        "width": 760,
        "height": 170,
        "x": 360,
        "y": 120,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "resizable": true
      },
      {
        "label": "selection-toolbar",
        "title": "LiveCaption Toolbar",
        "url": "index.html",
        "width": 246,
        "height": 44,
        "focus": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "resizable": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "worker/dist/livecaption-asr-worker": "asr-worker"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  }
}
