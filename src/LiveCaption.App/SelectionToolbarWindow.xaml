<Window x:Class="LiveCaption.App.SelectionToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ShowInTaskbar="False" Topmost="True" ShowActivated="False">
    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="11,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F5F5F7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Background" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Background" Property="Background" Value="#3A3A3C" /></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Background" Property="Opacity" Value="0.65" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#F21C1C1E" BorderBrush="#555559" BorderThickness="1" CornerRadius="8" Padding="7">
        <Border.Effect><DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.28" /></Border.Effect>
        <StackPanel Orientation="Horizontal">
            <Border Width="30" Height="30" Background="#007AFF" CornerRadius="8" Margin="0,2,6,2"><TextBlock Text="文" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
            <Button Content="翻译" Style="{StaticResource ToolbarButton}" Click="Translate_OnClick" />
            <Button Content="解释" Style="{StaticResource ToolbarButton}" Click="Explain_OnClick" />
            <Rectangle Width="1" Height="18" Fill="#48484A" Margin="4,0" VerticalAlignment="Center" />
            <Button Content="复制" Style="{StaticResource ToolbarButton}" Click="Copy_OnClick" />
        </StackPanel>
    </Border>
</Window>
