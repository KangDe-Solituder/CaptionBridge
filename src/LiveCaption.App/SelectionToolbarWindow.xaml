<Window x:Class="LiveCaption.App.SelectionToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ShowInTaskbar="False" Topmost="True" ShowActivated="False">
    <Border Background="#191919" BorderBrush="#434343" BorderThickness="1" CornerRadius="22" Padding="10,7">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="✦" Foreground="#FF6470" FontSize="22" VerticalAlignment="Center" Margin="4,0,10,0" />
            <Button Content="译 翻译" Background="Transparent" BorderThickness="0" Click="Translate_OnClick" />
            <Button Content="? 解释" Background="Transparent" BorderThickness="0" Click="Explain_OnClick" />
            <Button Content="复制" Background="Transparent" BorderThickness="0" Click="Copy_OnClick" />
        </StackPanel>
    </Border>
</Window>
