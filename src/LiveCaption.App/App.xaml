<Application x:Class="LiveCaption.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#111315" />
        <SolidColorBrush x:Key="PanelBackground" Color="#191C20" />
        <SolidColorBrush x:Key="PanelBorder" Color="#30343A" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F4F5F7" />
        <SolidColorBrush x:Key="TextSecondary" Color="#A7AFBA" />
        <SolidColorBrush x:Key="Accent" Color="#FF5D68" />
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#23272D" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="#41464F" />
            <Setter Property="Padding" Value="9,6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2B3037" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="#464C56" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Application.Resources>
</Application>
