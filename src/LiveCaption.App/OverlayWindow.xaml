<Window x:Class="LiveCaption.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ShowInTaskbar="False" Topmost="True" Opacity="0.9">
    <Border Background="#C916181B" BorderBrush="#6BFFFFFF" BorderThickness="1" CornerRadius="8" Padding="16,10">
        <StackPanel MaxWidth="880">
            <TextBlock x:Name="SourceText" Foreground="#C9D0D8" FontSize="17" TextWrapping="Wrap" />
            <TextBlock x:Name="TranslationText" Foreground="White" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,5,0,0" />
        </StackPanel>
    </Border>
</Window>
