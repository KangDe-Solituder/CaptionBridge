<Window x:Class="LiveCaption.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveCaption" Height="670" Width="820"
        Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="LiveCaption" FontSize="27" FontWeight="SemiBold" />
            <TextBlock Text="Windows Live Captions 的轻量翻译助手" Margin="0,5,0,0" Foreground="{StaticResource TextSecondary}" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="0,24,0,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="翻译服务" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0"><TextBlock Text="Endpoint" Foreground="{StaticResource TextSecondary}" /><TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Text="模型" Foreground="{StaticResource TextSecondary}" /><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0"><TextBlock Text="API Key" Foreground="{StaticResource TextSecondary}" /><PasswordBox x:Name="ApiKeyBox" PasswordChanged="ApiKeyBox_OnPasswordChanged" /></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Text="目标语言" Foreground="{StaticResource TextSecondary}" /><TextBox Text="{Binding TargetLanguage, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                        </Grid>
                        <TextBlock Text="高级 extra_body JSON" Foreground="{StaticResource TextSecondary}" Margin="0,10,0,0" />
                        <TextBox Text="{Binding ExtraBodyJson, UpdateSourceTrigger=PropertyChanged}" Height="48" TextWrapping="Wrap" AcceptsReturn="True" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0"><TextBlock Text="超时 (ms)" Foreground="{StaticResource TextSecondary}" /><TextBox Text="{Binding TimeoutMilliseconds, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0"><TextBlock Text="最大输出" Foreground="{StaticResource TextSecondary}" /><TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="温度" Foreground="{StaticResource TextSecondary}" /><TextBox Text="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="保存设置" Click="Save_OnClick" />
                            <Button Content="测试连接" Margin="8,0,0,0" Click="Test_OnClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="划词翻译" FontSize="16" FontWeight="SemiBold" />
                        <CheckBox Content="选择文本后显示翻译工具条" IsChecked="{Binding SelectionToolbarEnabled}" Margin="0,10,0,0" />
                        <CheckBox Content="允许剪贴板回退（兼容部分应用）" IsChecked="{Binding ClipboardFallbackEnabled}" Margin="0,6,0,0" />
                        <TextBlock Text="快捷键：Alt + Q" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="18">
                    <StackPanel>
                        <TextBlock Text="实时字幕" FontSize="16" FontWeight="SemiBold" />
                        <CheckBox Content="保留 Windows 原始字幕窗口" IsChecked="{Binding KeepSystemCaptionVisible}" Margin="0,10,0,0" />
                        <Button Content="{Binding LiveButtonText}" HorizontalAlignment="Left" Margin="0,12,0,0" Click="ToggleLive_OnClick" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Background="#20252C" CornerRadius="7" Padding="12,8"><TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" /></Border>
    </Grid>
</Window>
