<Window x:Class="LiveCaption.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveCaption" Width="1120" Height="760" MinWidth="900" MinHeight="620"
        Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize">
    <Border Background="{StaticResource Surface}" BorderBrush="#CBD5E1" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F9FBFD" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Border Width="20" Height="20" Background="{StaticResource Accent}" CornerRadius="6">
                            <TextBlock Text="C" Foreground="White" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="LiveCaption" FontWeight="SemiBold" Margin="9,0,0,0" />
                        <TextBlock Text="实时语境翻译" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="12,1,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="−" Style="{StaticResource WindowControlButton}" ToolTip="最小化" Click="MinimizeWindow_OnClick" />
                        <Button Content="□" Style="{StaticResource WindowControlButton}" ToolTip="最大化" Click="MaximizeWindow_OnClick" />
                        <Button Content="×" Style="{StaticResource WindowControlButton}" ToolTip="隐藏到通知区域" Click="CloseWindow_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Height" Value="34" />
                        <Setter Property="Padding" Value="17,0" />
                        <Setter Property="Margin" Value="0,0,8,0" />
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabSurface" Background="Transparent" CornerRadius="9" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabSurface" Property="Background" Value="{StaticResource AccentSoft}" />
                                            <Setter Property="Foreground" Value="{StaticResource Accent}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TabSurface" Property="Background" Value="#EDF2F7" /></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="58" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Border Background="#F9FBFD" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" HorizontalAlignment="Left" Margin="34,12,0,0" />
                            </Border>
                            <ContentPresenter Grid.Row="1" x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <TabItem Header="工作台">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="52,42,52,56" MaxWidth="920" HorizontalAlignment="Center" Opacity="0">
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22" /></Storyboard></BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>
                            <TextBlock Text="工作台" FontSize="30" FontWeight="SemiBold" />
                            <TextBlock Text="把实时字幕、划词翻译和当前服务状态放在同一个安静的工作空间里。" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,8,0,30" />

                            <Border Style="{StaticResource FeaturePanel}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="9" Height="9" Fill="{StaticResource Success}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="实时字幕" FontSize="17" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <TextBlock Text="启动后会打开 Windows Live Captions，并用 LiveCaption 浮层显示原文和译文。" Foreground="{StaticResource TextSecondary}" Margin="0,8,30,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{Binding LiveButtonText}" Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" Click="ToggleLive_OnClick" />
                                </Grid>
                            </Border>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Style="{StaticResource FeaturePanel}" Margin="0,0,9,0">
                                    <StackPanel>
                                        <TextBlock Text="划词翻译" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock Text="拖选文字后，在选区旁显示翻译、解释与复制工具。" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,18" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="全局快捷键" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" /><Border Background="#E7F2FF" CornerRadius="7" Padding="9,5" Margin="10,0,0,0"><TextBlock Text="Alt + Q" Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="12" /></Border></StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource FeaturePanel}" Margin="9,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="翻译服务" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock Text="默认适配 DeepSeek V4 Flash，也兼容 OpenAI Chat Completions。" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,18" TextWrapping="Wrap" />
                                        <Button Content="打开诊断日志" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="OpenDiagnostics_OnClick" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="当前状态" FontSize="17" FontWeight="SemiBold" Margin="0,34,0,12" />
                            <Border Background="#F7FAFC" BorderBrush="#E1E8EF" BorderThickness="1" CornerRadius="12" Padding="18">
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="52,42,52,56" MaxWidth="920" HorizontalAlignment="Center" Opacity="0">
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22" /></Storyboard></BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>
                            <TextBlock Text="设置" FontSize="30" FontWeight="SemiBold" />
                            <TextBlock Text="所有选项按使用顺序连续排列；保存后会立即应用于下一次翻译或字幕会话。" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,8,0,28" />

                            <TextBlock Text="翻译服务" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="连接任意 OpenAI Chat Completions 兼容服务。" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,12" />
                            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1,1,1,0" Background="#FCFDFE" CornerRadius="12,12,0,0">
                                <StackPanel>
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="服务地址" FontWeight="SemiBold" /><TextBlock Text="自动补全 /chat/completions" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><TextBox Grid.Column="1" Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" /></Grid>
                                    <Separator Background="{StaticResource BorderSubtle}" />
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="模型与目标语言" FontWeight="SemiBold" /><TextBlock Text="默认使用 DeepSeek V4 Flash 的非思考模式。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><Grid Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="150" /></Grid.ColumnDefinitions><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Column="2" Text="{Binding TargetLanguage, UpdateSourceTrigger=PropertyChanged}" /></Grid></Grid>
                                    <Separator Background="{StaticResource BorderSubtle}" />
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="API Key" FontWeight="SemiBold" /><TextBlock Text="使用 Windows DPAPI 加密保存。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><PasswordBox x:Name="ApiKeyBox" Grid.Column="1" PasswordChanged="ApiKeyBox_OnPasswordChanged" /></Grid>
                                </StackPanel>
                            </Border>
                            <Border Background="#F7FAFC" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="0,0,12,12" Padding="20,15">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,18,0" /><Button Grid.Column="1" Content="{Binding TestButtonText}" IsEnabled="{Binding CanTestConnection}" Style="{StaticResource SecondaryButton}" Click="Test_OnClick" /></Grid>
                            </Border>

                            <TextBlock Text="请求参数" FontSize="18" FontWeight="SemiBold" Margin="0,34,0,12" />
                            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Background="#FCFDFE" CornerRadius="12">
                                <StackPanel>
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="超时、最大输出与温度" FontWeight="SemiBold" /><TextBlock Text="控制响应速度与输出长度。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><Grid Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBox Text="{Binding TimeoutMilliseconds, UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Column="2" Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Column="4" Text="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}" /></Grid></Grid>
                                    <Separator Background="{StaticResource BorderSubtle}" />
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Extra body JSON" FontWeight="SemiBold" /><TextBlock Text="默认包含关闭思考模式的参数。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><TextBox Grid.Column="1" Text="{Binding ExtraBodyJson, UpdateSourceTrigger=PropertyChanged}" Height="74" Padding="12,8" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" /></Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="划词翻译" FontSize="18" FontWeight="SemiBold" Margin="0,34,0,12" />
                            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Background="#FCFDFE" CornerRadius="12">
                                <StackPanel>
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="自动显示工具条" FontWeight="SemiBold" /><TextBlock Text="完成拖选后显示翻译、解释和复制。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><CheckBox Grid.Column="1" Style="{StaticResource SwitchStyle}" IsChecked="{Binding SelectionToolbarEnabled}" VerticalAlignment="Center" /></Grid>
                                    <Separator Background="{StaticResource BorderSubtle}" />
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="安全剪贴板取词" FontWeight="SemiBold" /><TextBlock Text="读取后仅在剪贴板未被其他应用更新时恢复原内容。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><CheckBox Grid.Column="1" Style="{StaticResource SwitchStyle}" IsChecked="{Binding ClipboardFallbackEnabled}" VerticalAlignment="Center" /></Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="实时字幕" FontSize="18" FontWeight="SemiBold" Margin="0,34,0,12" />
                            <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Background="#FCFDFE" CornerRadius="12">
                                <StackPanel>
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="保留 Windows 原字幕" FontWeight="SemiBold" /><TextBlock Text="关闭后仅显示 LiveCaption 的原文与译文浮层。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><CheckBox Grid.Column="1" Style="{StaticResource SwitchStyle}" IsChecked="{Binding KeepSystemCaptionVisible}" VerticalAlignment="Center" /></Grid>
                                    <Separator Background="{StaticResource BorderSubtle}" />
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="断句节奏" FontWeight="SemiBold" /><TextBlock Text="依次为稳定时间、最长等待和最大字符数。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><Grid Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBox Text="{Binding StableMilliseconds, UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Column="2" Text="{Binding MaximumDurationMilliseconds, UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Column="4" Text="{Binding MaximumLength, UpdateSourceTrigger=PropertyChanged}" /></Grid></Grid>
                                    <Separator Background="{StaticResource BorderSubtle}" />
                                    <Grid Margin="20,18"><Grid.ColumnDefinitions><ColumnDefinition Width="250" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="字幕浮层" FontWeight="SemiBold" /><TextBlock Text="依次为字体大小、透明度和始终置顶。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel><Grid Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /><ColumnDefinition Width="20" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox Text="{Binding OverlayFontSize, UpdateSourceTrigger=PropertyChanged}" /><TextBox Grid.Column="2" Text="{Binding OverlayOpacity, UpdateSourceTrigger=PropertyChanged}" /><CheckBox Grid.Column="4" Style="{StaticResource SwitchStyle}" IsChecked="{Binding OverlayAlwaysOnTop}" VerticalAlignment="Center" /></Grid></Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                                <Button Content="打开诊断日志" Style="{StaticResource SecondaryButton}" Click="OpenDiagnostics_OnClick" />
                                <Button Content="保存所有设置" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Click="Save_OnClick" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
