<Window x:Class="LiveCaption.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveCaption" Width="1080" Height="720" MinWidth="900" MinHeight="620"
        Background="{StaticResource AppBackground}" Foreground="{StaticResource TextPrimary}"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="WindowDotButton" TargetType="Button">
            <Setter Property="Width" Value="13" />
            <Setter Property="Height" Value="13" />
            <Setter Property="Margin" Value="0,0,9,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Ellipse Fill="{TemplateBinding Background}" Stroke="#1A000000" StrokeThickness="0.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#D7D7DC" BorderThickness="1" Background="{StaticResource Surface}">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="44" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#F5F5F7" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="17,0,0,0">
                        <Button Background="#FF5F57" Style="{StaticResource WindowDotButton}" ToolTip="隐藏到托盘" Click="CloseWindow_OnClick" />
                        <Button Background="#FEBC2E" Style="{StaticResource WindowDotButton}" ToolTip="最小化" Click="MinimizeWindow_OnClick" />
                        <Button Background="#28C840" Style="{StaticResource WindowDotButton}" ToolTip="最大化" Click="MaximizeWindow_OnClick" />
                    </StackPanel>
                    <TextBlock Text="LiveCaption" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#7A7A80" />
                </Grid>
            </Border>
    <TabControl Grid.Row="1" x:Name="RootTabs" TabStripPlacement="Left" BorderThickness="0" Background="Transparent">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Width" Value="184" />
                <Setter Property="Height" Value="42" />
                <Setter Property="Margin" Value="18,2" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="NavBackground" Background="Transparent" CornerRadius="7" Padding="13,0">
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="NavBackground" Property="Background" Value="{StaticResource Surface}" />
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="NavBackground" Property="Background" Value="#ECECEF" /></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>
        <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource AppBackground}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Margin="30,28,24,24">
                                <TextBlock Text="LiveCaption" FontSize="23" FontWeight="SemiBold" />
                                <TextBlock Text="听见，也表达得更好" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Bottom" Margin="31,0,24,24">
                                <TextBlock Text="Version 0.1" Foreground="#9A9AA0" FontSize="11" />
                            </StackPanel>
                            <TabPanel IsItemsHost="True" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource Surface}">
                        <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </TabControl.Template>

        <TabItem>
            <TabItem.Header><StackPanel Orientation="Horizontal"><TextBlock Text="⌂" Width="25" FontSize="17" /><TextBlock Text="概览" /></StackPanel></TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48,38" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="概览" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="翻译服务、划词工具和实时字幕都从这里开始。" Foreground="{StaticResource TextSecondary}" Margin="0,7,0,28" />
                    <Border Style="{StaticResource SettingsGroup}" Padding="22">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="实时字幕" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="主动启动 Windows Live Captions，并在独立浮层显示原文与译文。" Foreground="{StaticResource TextSecondary}" Margin="0,5,24,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="{Binding LiveButtonText}" Style="{StaticResource PrimaryButton}" Click="ToggleLive_OnClick" />
                        </Grid>
                    </Border>
                    <TextBlock Text="当前状态" FontSize="15" FontWeight="SemiBold" Margin="0,28,0,10" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
                            <Separator Background="{StaticResource BorderSubtle}" Margin="0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="模型" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBlock Text="{Binding Model}" Margin="0,3,0,0" /></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Text="目标语言" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBlock Text="{Binding TargetLanguage}" Margin="0,3,0,0" /></StackPanel>
                            </Grid>
                            <Separator Background="{StaticResource BorderSubtle}" Margin="0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="诊断日志" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                                    <TextBlock Text="{Binding DiagnosticsPath}" TextTrimming="CharacterEllipsis" Margin="0,3,16,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="打开目录" Style="{StaticResource SecondaryButton}" Click="OpenDiagnostics_OnClick" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="快速开始" FontSize="15" FontWeight="SemiBold" Margin="0,28,0,10" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <TextBlock Text="1  在“翻译服务”中填写 API Key 并测试连接" />
                            <TextBlock Text="2  选择任意文字，使用浮动工具条翻译或解释" Margin="0,12,0,0" />
                            <TextBlock Text="3  启动实时字幕，观察独立字幕浮层" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem>
            <TabItem.Header><StackPanel Orientation="Horizontal"><TextBlock Text="文" Width="25" FontWeight="SemiBold" /><TextBlock Text="翻译服务" /></StackPanel></TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48,38" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="翻译服务" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="兼容 OpenAI Chat Completions；默认预设为 DeepSeek V4 Flash 非思考模式。" Foreground="{StaticResource TextSecondary}" Margin="0,7,0,28" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <TextBlock Text="服务地址" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,14" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0"><TextBlock Text="模型" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="目标语言" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding TargetLanguage, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                            </Grid>
                            <TextBlock Text="API Key" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,14,0,0" /><PasswordBox x:Name="ApiKeyBox" PasswordChanged="ApiKeyBox_OnPasswordChanged" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="高级参数" FontSize="15" FontWeight="SemiBold" Margin="0,28,0,10" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0"><TextBlock Text="超时 (ms)" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding TimeoutMilliseconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0"><TextBlock Text="最大输出" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0"><TextBlock Text="温度" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                            </Grid>
                            <TextBlock Text="Extra body JSON" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,14,0,0" />
                            <TextBox Text="{Binding ExtraBodyJson, UpdateSourceTrigger=PropertyChanged}" Height="62" Margin="0,6,0,0" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" />
                        </StackPanel>
                    </Border>
                    <Border Background="#F5F5F7" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" CornerRadius="7" Padding="14,10" Margin="0,18,0,0">
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="{Binding TestButtonText}" IsEnabled="{Binding CanTestConnection}" Style="{StaticResource SecondaryButton}" Click="Test_OnClick" />
                        <Button Content="保存设置" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="Save_OnClick" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem>
            <TabItem.Header><StackPanel Orientation="Horizontal"><TextBlock Text="⌁" Width="25" FontSize="17" /><TextBlock Text="划词翻译" /></StackPanel></TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48,38" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="划词翻译" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="选择文字后出现紧凑工具条；只有点击翻译或解释时才会调用 API。" Foreground="{StaticResource TextSecondary}" Margin="0,7,0,28" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="自动显示工具条" FontWeight="SemiBold" /><TextBlock Text="在鼠标选择完成后显示“翻译 / 解释 / 复制”。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,20,0" /></StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SwitchStyle}" IsChecked="{Binding SelectionToolbarEnabled}" VerticalAlignment="Center" />
                            </Grid>
                            <Separator Background="{StaticResource BorderSubtle}" Margin="0,18" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="安全剪贴板取词" FontWeight="SemiBold" /><TextBlock Text="只在确认发生拖选后短暂复制文字，并在读取后恢复原剪贴板。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,20,0" /></StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SwitchStyle}" IsChecked="{Binding ClipboardFallbackEnabled}" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="快捷键" FontSize="15" FontWeight="SemiBold" Margin="0,28,0,10" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="随时翻译当前选区" FontWeight="SemiBold" /><TextBlock Text="当自动工具条未出现时使用。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" /></StackPanel>
                            <Border Grid.Column="1" Background="White" BorderBrush="#D1D1D6" BorderThickness="1" CornerRadius="6" Padding="12,7"><TextBlock Text="Alt + Q" FontWeight="SemiBold" /></Border>
                        </Grid>
                    </Border>
                    <Button Content="保存设置" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Margin="0,20,0,0" Click="Save_OnClick" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem>
            <TabItem.Header><StackPanel Orientation="Horizontal"><TextBlock Text="CC" Width="25" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" /><TextBlock Text="实时字幕" /></StackPanel></TabItem.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="48,38" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="实时字幕" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="控制 Windows Live Captions、基础断句与字幕浮层。" Foreground="{StaticResource TextSecondary}" Margin="0,7,0,28" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="保留系统字幕窗口" FontWeight="SemiBold" /><TextBlock Text="关闭后只显示 LiveCaption 自己的原文与译文浮层。" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,20,0" /></StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource SwitchStyle}" IsChecked="{Binding KeepSystemCaptionVisible}" VerticalAlignment="Center" />
                            </Grid>
                            <Separator Background="{StaticResource BorderSubtle}" Margin="0,18" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0"><TextBlock Text="稳定时间 (ms)" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding StableMilliseconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0"><TextBlock Text="最长等待 (ms)" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding MaximumDurationMilliseconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0"><TextBlock Text="最大字符数" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding MaximumLength, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="字幕浮层" FontSize="15" FontWeight="SemiBold" Margin="0,28,0,10" />
                    <Border Style="{StaticResource SettingsGroup}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,0"><TextBlock Text="字号" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding OverlayFontSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0"><TextBlock Text="透明度 (0-1)" Foreground="{StaticResource TextSecondary}" FontSize="12" /><TextBox Text="{Binding OverlayOpacity, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" /></StackPanel>
                            <StackPanel Grid.Column="2" Margin="24,0,0,0" VerticalAlignment="Center"><TextBlock Text="始终置顶" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6" /><CheckBox Style="{StaticResource SwitchStyle}" IsChecked="{Binding OverlayAlwaysOnTop}" /></StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="保存设置" Style="{StaticResource SecondaryButton}" Click="Save_OnClick" />
                        <Button Content="{Binding LiveButtonText}" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="ToggleLive_OnClick" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
        </Grid>
    </Border>
</Window>
