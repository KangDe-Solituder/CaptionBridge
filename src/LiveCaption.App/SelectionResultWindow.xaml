<Window x:Class="LiveCaption.App.SelectionResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="390" SizeToContent="Height" ShowInTaskbar="False" Topmost="True">
    <Border Background="#202226" BorderBrush="#4A505A" BorderThickness="1" CornerRadius="10" Padding="14">
        <StackPanel>
            <DockPanel><TextBlock x:Name="TitleText" FontWeight="SemiBold" Foreground="#F4F5F7" /><Button DockPanel.Dock="Right" Content="×" Background="Transparent" BorderThickness="0" Click="Close_OnClick" /></DockPanel>
            <TextBlock x:Name="SourceText" Foreground="#A7AFBA" TextWrapping="Wrap" Margin="0,8,0,4" MaxHeight="70" />
            <TextBlock x:Name="ResultText" Foreground="#FFFFFF" TextWrapping="Wrap" FontSize="15" />
            <DockPanel Margin="0,10,0,0"><TextBlock x:Name="LatencyText" Foreground="#8D96A3" FontSize="11" /><Button DockPanel.Dock="Right" Content="复制结果" Click="Copy_OnClick" /></DockPanel>
        </StackPanel>
    </Border>
</Window>
